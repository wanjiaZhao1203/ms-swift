# Private bundled deps — not for public distribution.
# ttcc-eval is Liangyu's private repo; kept locally so Modal images can build
# from it without a GitHub PAT, but should not appear in any public commit.
third_party/

# Local data + checkpoints — too large for git and lives on the Modal volume.
data/raw/
data/audios/
data/videos/
data/splits/
# Ignore inside runs/ except the small JSON reports we want tracked.
runs/*
!runs/reports/
!runs/reports/**

# Python build / cache.
__pycache__/
*.pyc
.pytest_cache/
.ipynb_checkpoints/

# Editor / OS junk.
.DS_Store
.vscode/
.idea/
